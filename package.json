{
  "name": "elegance-sconia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:client\"",
    "dev:server": "nodemon",
    "dev:client": "node scripts/with-env.js concurrently \"webpack --config webpack.account.js --watch\" \"webpack --config webpack.inventory.js --watch\" \"webpack --config webpack.store.js --watch\"",
    "build": "node scripts/with-env.js webpack --config webpack.account.js && node scripts/with-env.js webpack --config webpack.inventory.js && node scripts/with-env.js webpack --config webpack.store.js",
    "start": "node scripts/with-env.js node -r ts-node/register src/server/app.ts",
    "migrate": "node scripts/with-env.js knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "node scripts/with-env.js knex --knexfile knexfile.ts migrate:rollback",
    "migrate:make": "node scripts/with-env.js knex --knexfile knexfile.ts migrate:make",
    "migrate:status": "node scripts/with-env.js knex --knexfile knexfile.ts migrate:status",
    "seed:permissions": "node scripts/with-env.js ts-node src/server/startup/ensurePermissions.ts",
    "seed:settings": "node scripts/with-env.js ts-node src/server/startup/ensureSettings.ts",
    "seed:owner": "node scripts/with-env.js ts-node src/server/startup/ensureOwnerAccount.ts",
    "test": "node scripts/with-env.js jest",
    "test:align": "node scripts/with-env.js jest --testPathPattern=\"\\.align\\.test\\.\"",
    "test:unit": "node scripts/with-env.js jest --testPathIgnorePatterns=\"align\"",
    "test:watch": "node scripts/with-env.js jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/test/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "moduleNameMapper": {
      "^@client/(.*)$": "<rootDir>/src/client/$1",
      "^@server/(.*)$": "<rootDir>/src/server/$1"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@mantine/core": "^7.5.0",
    "@mantine/hooks": "^7.5.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.1",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "formik": "^2.4.5",
    "helmet": "^7.1.0",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.8",
    "objection": "^3.1.3",
    "paystack": "^2.0.1",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "redis": "^4.6.13",
    "sharp": "^0.33.2",
    "sweetalert2": "^11.10.2",
    "uuid": "^9.0.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "1.18.2",
    "@types/jest": "29",
    "@types/multer": "1.4.12",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^20.11.5",
    "@types/node-schedule": "^2.1.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.3",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.11.8",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "29",
    "mini-css-extract-plugin": "^2.8.0",
    "nodemon": "^3.0.3",
    "sass": "^1.70.0",
    "sass-loader": "^14.1.0",
    "style-loader": "^3.3.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "resolutions": {
    "@types/express": "4.17.25",
    "@types/express-serve-static-core": "4.19.8"
  }
}
