{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "dist/client",
    "rootDir": "src/client"
  },
  "include": ["src/client/**/*"],
  "exclude": ["node_modules", "dist", "src/server"]
}
